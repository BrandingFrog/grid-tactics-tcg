__pycache__/
*.py[cod]
*$py.class
.venv/
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg
.env
.pod_costs.json
*.db
tb_logs/
wandb/
.coverage

# Phase 14.6: sandbox slot files are user-local, not committed
data/sandbox_saves/*
!data/sandbox_saves/.gitkeep

# GT-DEBUG file sink (server-side debug-code contexts)
logs/

# Local editor and browser-automation state
.claude/settings.local.json
.obsidian/
.playwright-mcp/
.benchmarks/

# Local QA captures. Keep the index, not hundreds of generated screenshots.
/artifacts/*
!/artifacts/README.md
/*.png
/*.jpg
/*.jpeg
/*.svg

# Transient debug output
*.log
/expected-tmp.json
/scripts/*_output.txt
