# Grid Tactics Wiki — environment configuration
# Copy to .env and adjust. DO NOT commit .env.
#
#   cp .env.example .env
#
# MW_SECRET_KEY MUST be at least 32 characters for MediaWiki to boot cleanly.

# --- MediaWiki site ---
MW_SITE_NAME=Grid Tactics Wiki
MW_SITE_SERVER=http://localhost:8080
MW_SITE_LANG=en

# --- MediaWiki admin (auto-created on first boot) ---
MW_ADMIN_USER=admin
MW_ADMIN_PASS=devpassword

# --- MediaWiki -> DB link (must match MARIADB_* below) ---
# MW_DB_INSTALLDB_* is only used on first boot to create the wiki schema;
# it defaults to root / ${MARIADB_ROOT_PASSWORD} via docker-compose.yml.
MW_DB_NAME=wiki
MW_DB_USER=wiki
MW_DB_PASS=wikipass

# --- MediaWiki secret (>=32 chars!) ---
MW_SECRET_KEY=dev-secret-change-me-32chars-minim

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=rootpass
MARIADB_DATABASE=wiki
MARIADB_USER=wiki
MARIADB_PASSWORD=wikipass

# --- Sync bot credentials (filled in plan 01-02 Task 2) ---
# Created via maintenance/createBotPassword.php inside the mediawiki container.
# MW_BOT_USER is the full "<username>@<appid>" form mwclient expects.
MW_API_URL=http://localhost:8080/
MW_BOT_USER=admin@phase1
MW_BOT_PASS=
