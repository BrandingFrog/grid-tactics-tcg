# Grid Tactics Wiki — environment configuration
# Copy to .env and adjust. DO NOT commit .env.
#
#   cp .env.example .env
#
# MW_SECRET_KEY MUST be at least 32 characters for MediaWiki to boot cleanly.

# --- MediaWiki site ---
MW_SITE_NAME=Grid Tactics Wiki
MW_SITE_SERVER=http://localhost:8080
MW_SITE_LANG=en

# --- MediaWiki admin (auto-created on first boot) ---
MW_ADMIN_USER=admin
MW_ADMIN_PASS=devpassword

# --- MediaWiki -> DB link (must match MARIADB_* below) ---
MW_DB_NAME=wiki
MW_DB_USER=wiki
MW_DB_PASS=wikipass

# --- MediaWiki secret (>=32 chars!) ---
MW_SECRET_KEY=dev-secret-change-me-32chars-minim

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=rootpass
MARIADB_DATABASE=wiki
MARIADB_USER=wiki
MARIADB_PASSWORD=wikipass
